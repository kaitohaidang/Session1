import java.util.Scanner;

public class DienTichHinhTron {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        System.out.println("--- CHƯƠNG TRÌNH TÍNH DIỆN TÍCH HÌNH TRÒN ---");
        System.out.print("Vui lòng nhập bán kính của hình tròn: ");

        if (scanner.hasNextDouble()) {
            double radius = scanner.nextDouble();

            if (radius <= 0) {
                System.out.println("Lỗi: Bán kính phải là một số dương lớn hơn 0!");
            } else {
                double area = Math.PI * radius * radius;

                System.out.println("Bán kính đã nhập: " + radius);
                System.out.println("Diện tích hình tròn là: " + area);

                System.out.printf("Diện tích (làm tròn): %.2f\n", area);
            }
        } else {
            System.out.println("Lỗi: Dữ liệu nhập vào không hợp lệ. Vui lòng nhập một số!");
        }

        scanner.close();
    }
}
